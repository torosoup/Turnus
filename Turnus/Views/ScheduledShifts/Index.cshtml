@model IEnumerable<Turnus.Models.ScheduledShift>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Venue</th>
            <th>Date</th>
            <th>Shift</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ScheduledDay?.Venue?.Name</td>
                <td>@item.ScheduledDay?.Date.ToShortDateString()</td>
                <td>@item.ShiftDefinition?.Name (@item.ShiftDefinition?.StartTime - @item.ShiftDefinition?.EndTime)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>