@model Turnus.Models.ScheduledShift

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>ScheduledShift</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label asp-for="ScheduledDayId" class="control-label">Scheduled Day</label>
                <select asp-for="ScheduledDayId" class="form-control" asp-items="ViewBag.ScheduledDayId"></select>
                <span asp-validation-for="ScheduledDayId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ShiftDefinitionId" class="control-label">Shift</label>
                <select asp-for="ShiftDefinitionId" class="form-control" asp-items="ViewBag.ShiftDefinitionId"></select>
                <span asp-validation-for="ShiftDefinitionId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>