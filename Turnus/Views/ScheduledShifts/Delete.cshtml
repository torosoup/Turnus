@model Turnus.Models.ScheduledShift

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>ScheduledShift</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Venue</dt>
        <dd class="col-sm-10">@Model?.ScheduledDay?.Venue?.Name</dd>

        <dt class="col-sm-2">Date</dt>
        <dd class="col-sm-10">@Model?.ScheduledDay?.Date.ToShortDateString()</dd>

        <dt class="col-sm-2">Shift</dt>
        <dd class="col-sm-10">@Model?.ShiftDefinition?.Name (@Model?.ShiftDefinition?.StartTime - @Model?.ShiftDefinition?.EndTime)</dd>
    </dl>
    <form asp-action="Delete">
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Back to List</a>
    </form>
</div>